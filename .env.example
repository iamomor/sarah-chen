# ─────────────────────────────────────────────────────────────
# Sarah Chen Realty — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env.local
# 2. Replace every REPLACE_ME with your real credentials.
# 3. NEVER commit .env.local — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────

# ── EmailJS ────────────────────────────────────────────────────
# Get these from: emailjs.com → Account → API Keys & Email Services
NEXT_PUBLIC_EMAILJS_SERVICE_ID=REPLACE_ME
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=REPLACE_ME
NEXT_PUBLIC_EMAILJS_TEMPLATE_CONTACT=REPLACE_ME
NEXT_PUBLIC_EMAILJS_TEMPLATE_VALUATION=REPLACE_ME
NEXT_PUBLIC_EMAILJS_TEMPLATE_SHOWING=REPLACE_ME
NEXT_PUBLIC_EMAILJS_TEMPLATE_NEWSLETTER=REPLACE_ME

# ── Analytics ─────────────────────────────────────────────────
# Google Analytics 4
# Get this from: analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA4_ID=REPLACE_ME

# Meta Pixel
# Get this from: business.facebook.com → Events Manager → Pixel → Settings
NEXT_PUBLIC_META_PIXEL_ID=REPLACE_ME

# ── Crisp Live Chat ───────────────────────────────────────────
# Get this from: crisp.chat → Settings → Setup & Integrations → SDK
NEXT_PUBLIC_CRISP_WEBSITE_ID=REPLACE_ME

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── OpenRouter AI (optional — used for AI chat features) ──────
# Get this from: openrouter.ai → Keys → Create key
OPENROUTER_API_KEY=REPLACE_ME
